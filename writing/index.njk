---
title: "Writing & Blog"
layout: "base.njk"
pagination:
  data: collections.posts
  size: 10
  alias: posts
---

<section class="writing-page-wrapper">

  <header class="writing-header">
    <h1>Writing & Publications</h1>
    <p class="writing-subtitle">
      Stories, poems, and essays across platforms.
    </p>
  </header>


  <!-- BLOG POSTS -->
  <main class="blog-list">

    {% for post in posts | reverse %}
      <article class="blog-item">

        <div class="blog-top">
          <h2 class="blog-title">
            <a href="{{ post.url | url }}">{{ post.data.title }}</a>
          </h2>

          <time class="blog-date">
            {{ post.date | date("MMMM d, yyyy") }}
          </time>
        </div>

        <p class="blog-excerpt">
          {{ post.templateContent | truncate(170, true, '...') | safe }}
        </p>

        <a class="blog-read" href="{{ post.url | url }}">
          Read →
        </a>

      </article>
    {% endfor %}

  </main>

</section>