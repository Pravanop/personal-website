---
title: "Writing & Blog"
layout: "base.njk"
---

<section class="writing-page">

  <h1 class="page-title">Writing & Publications</h1>
  <p class="page-subtitle">
    Stories, poems, and essays published across platforms.
  </p>

  <div class="bulletin">

    {% for post in collections.posts | reverse %}
      <div class="bulletin-item">

        <div class="bulletin-main">
          <h2>
            <a href="{{ post.data.link or post.url | url }}" target="_blank">
              {{ post.data.title }}
            </a>
          </h2>

          <p class="bulletin-meta">
            {{ post.data.place }} •
            {{ post.date | date("MMMM d, yyyy") }}
          </p>

          {% if post.data.description %}
            <p class="bulletin-desc">
              {{ post.data.description }}
            </p>
          {% endif %}
        </div>

        <div class="bulletin-link">
          <a href="{{ post.data.link or post.url | url }}" target="_blank">
            Read →
          </a>
        </div>

      </div>
    {% endfor %}

  </div>

</section>